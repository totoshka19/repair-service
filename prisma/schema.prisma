generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

model User {
  id           String         @id @default(cuid())
  username     String         @unique
  passwordHash String
  role         Role
  requests     Request[]      @relation("AssignedTo")
  events       RequestEvent[]
  createdAt    DateTime       @default(now())
}

model Request {
  id          String         @id @default(cuid())
  clientName  String
  phone       String
  address     String
  problemText String
  status      Status         @default(NEW)
  assignedTo  String?
  master      User?          @relation("AssignedTo", fields: [assignedTo], references: [id])
  events      RequestEvent[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model RequestEvent {
  id        String   @id @default(cuid())
  requestId String
  request   Request  @relation(fields: [requestId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  comment   String?
  createdAt DateTime @default(now())
}

enum Role {
  DISPATCHER
  MASTER
}

enum Status {
  NEW
  ASSIGNED
  IN_PROGRESS
  DONE
  CANCELED
}
